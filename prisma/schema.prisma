generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DELETED
}

enum MembershipRole {
  OWNER
  ADMIN
  STAFF
  VIEWER
}

enum BusinessStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum BusinessCategory {
  HEALTH
  BEAUTY
  EDUCATION
  CONSULTING
  SPORTS
  OTHER
}

enum OnboardingStep {
  BUSINESS
  SERVICES
  AVAILABILITY
  LINK
  COMPLETED
}

enum LocationType {
  HEADQUARTERS
  BRANCH
  MOBILE
  ONLINE
}

enum ProfessionalStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ServicePrepaymentMode {
  NONE
  DEPOSIT
  FULL
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentSource {
  PUBLIC_PAGE
  DASHBOARD
  API
  IMPORT
}

enum AccessTokenPurpose {
  CANCEL
  RESCHEDULE
  REVIEW
}

enum BillingProvider {
  STRIPE
  MERCADOPAGO
  PAGARME
  MANUAL
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  UNPAID
  CANCELED
  INCOMPLETE
  PAUSED
  EXPIRED
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
}

enum NotificationType {
  APPOINTMENT_CREATED
  APPOINTMENT_CONFIRMED
  APPOINTMENT_CANCELLED
  APPOINTMENT_RESCHEDULED
  REMINDER_24H
  REMINDER_1H
  REVIEW_REQUEST
  BILLING_PAST_DUE
  BILLING_RENEWED
}

enum NotificationStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  CANCELED
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  HIDDEN
}

enum PrivacyRequestType {
  ACCESS
  DELETE
}

enum PrivacyRequestStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum DataExportFormat {
  CSV
  PDF
  JSON
}

enum DataExportScope {
  AGGREGATED
  FULL_CUSTOMERS
}

enum PlanCode {
  STARTER
  PRO
  BUSINESS
}

model User {
  id             String                     @id @default(cuid())
  name           String?
  email          String                     @unique
  emailVerified  DateTime?
  image          String?
  passwordHash   String?
  phone          String?
  locale         String?                    @default("pt-BR")
  status         UserStatus                 @default(ACTIVE)
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  deletedAt      DateTime?
  accounts       Account[]
  sessions       Session[]
  memberships    Membership[]
  statusHistory  AppointmentStatusHistory[]
  dataExports    DataExport[]
  notifications  Notification[]
  authenticators Authenticator[]

  @@index([createdAt])
  @@index([status])
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([createdAt])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Authenticator {
  credentialID         String   @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
  @@index([createdAt])
}

model Business {
  id                         String                   @id @default(cuid())
  name                       String
  legalName                  String?
  slug                       String                   @unique
  category                   BusinessCategory
  status                     BusinessStatus           @default(DRAFT)
  description                String?                  @db.Text
  phone                      String?
  email                      String?
  websiteUrl                 String?
  googleBusinessProfileUrl   String?
  timezone                   String                   @default("America/Sao_Paulo")
  logoUrl                    String?
  coverImageUrl              String?
  brandPrimaryColor          String?                  @default("#1664E8")
  brandSecondaryColor        String?                  @default("#1254C7")
  publicBookingEnabled       Boolean                  @default(false)
  publicBookingPaused        Boolean                  @default(false)
  indexable                  Boolean                  @default(true)
  customDomain               String?                  @unique
  bookingTitle               String?
  seoTitle                   String?
  seoDescription             String?                  @db.Text
  addressLine1               String?
  addressLine2               String?
  neighborhood               String?
  city                       String?
  state                      String?
  postalCode                 String?
  country                    String?                  @default("BR")
  latitude                   Decimal?                 @db.Decimal(10, 7)
  longitude                  Decimal?                 @db.Decimal(10, 7)
  cancellationPolicyText     String?                  @db.Text
  cancellationNoticeMinutes  Int                      @default(120)
  rescheduleNoticeMinutes    Int                      @default(120)
  minimumLeadTimeMinutes     Int                      @default(60)
  bookingLinkTokenTtlMinutes Int                      @default(1440)
  onboardingStep             OnboardingStep           @default(BUSINESS)
  onboardingCompletedAt      DateTime?
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt
  deletedAt                  DateTime?
  memberships                Membership[]
  locations                  BusinessLocation[]
  professionals              Professional[]
  services                   Service[]
  serviceVariants            ServiceVariant[]
  professionalServices       ProfessionalService[]
  availabilities             Availability[]
  availabilityBlocks         AvailabilityBlock[]
  customers                  Customer[]
  appointments               Appointment[]
  appointmentTokens          AppointmentAccessToken[]
  notifications              Notification[]
  notificationTemplates      NotificationTemplate[]
  reviews                    Review[]
  subscriptions              Subscription[]
  privacyRequests            PrivacyRequest[]
  usageMonths                BusinessUsageMonth[]
  exports                    DataExport[]
  professionalLocations      ProfessionalLocation[]

  @@index([createdAt])
  @@index([status])
}

model Membership {
  id         String         @id @default(cuid())
  businessId String
  userId     String
  role       MembershipRole @default(STAFF)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  business   Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([createdAt])
  @@index([role])
}

model BusinessLocation {
  id            String                 @id @default(cuid())
  businessId    String
  name          String
  type          LocationType           @default(HEADQUARTERS)
  isPrimary     Boolean                @default(false)
  phone         String?
  email         String?
  timezone      String
  addressLine1  String?
  addressLine2  String?
  neighborhood  String?
  city          String?
  state         String?
  postalCode    String?
  country       String?                @default("BR")
  latitude      Decimal?               @db.Decimal(10, 7)
  longitude     Decimal?               @db.Decimal(10, 7)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  deletedAt     DateTime?
  business      Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  professionals ProfessionalLocation[]
  appointments  Appointment[]

  @@index([businessId, isPrimary])
  @@index([createdAt])
}

model Professional {
  id                    String                 @id @default(cuid())
  businessId            String
  displayName           String
  publicDisplayName     String?
  roleLabel             String?
  slug                  String?
  email                 String?
  phone                 String?
  bio                   String?                @db.Text
  photoUrl              String?
  coverImageUrl         String?
  timezoneOverride      String?
  specialties           String[]               @default([])
  status                ProfessionalStatus     @default(ACTIVE)
  acceptsOnlineBookings Boolean                @default(true)
  sortOrder             Int                    @default(0)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  deletedAt             DateTime?
  business              Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  locations             ProfessionalLocation[]
  services              ProfessionalService[]
  availabilities        Availability[]
  availabilityBlocks    AvailabilityBlock[]
  appointments          Appointment[]
  reviews               Review[]

  @@unique([businessId, slug])
  @@index([businessId, status])
  @@index([createdAt])
}

model ProfessionalLocation {
  id             String           @id @default(cuid())
  businessId     String
  professionalId String
  locationId     String
  createdAt      DateTime         @default(now())
  business       Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  professional   Professional     @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  location       BusinessLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([professionalId, locationId])
  @@index([createdAt])
}

model Service {
  id                    String                @id @default(cuid())
  businessId            String
  name                  String
  slug                  String?
  description           String?               @db.Text
  durationMinutes       Int
  bufferAfterMinutes    Int                   @default(0)
  priceCents            Int
  colorHex              String?
  isActive              Boolean               @default(true)
  sortOrder             Int                   @default(0)
  prepaymentMode        ServicePrepaymentMode @default(NONE)
  prepaymentAmountCents Int?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  deletedAt             DateTime?
  business              Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  variants              ServiceVariant[]
  professionals         ProfessionalService[]
  appointments          Appointment[]

  @@unique([businessId, slug])
  @@index([businessId, isActive, sortOrder])
  @@index([createdAt])
}

model ServiceVariant {
  id                    String                @id @default(cuid())
  businessId            String
  serviceId             String
  name                  String
  durationMinutes       Int
  priceCents            Int
  isActive              Boolean               @default(true)
  sortOrder             Int                   @default(0)
  prepaymentMode        ServicePrepaymentMode @default(NONE)
  prepaymentAmountCents Int?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  deletedAt             DateTime?
  business              Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  service               Service               @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  appointments          Appointment[]

  @@index([serviceId, isActive, sortOrder])
  @@index([createdAt])
}

model ProfessionalService {
  id             String       @id @default(cuid())
  businessId     String
  professionalId String
  serviceId      String
  createdAt      DateTime     @default(now())
  business       Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service        Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([professionalId, serviceId])
  @@index([createdAt])
}

model Availability {
  id                  String       @id @default(cuid())
  businessId          String
  professionalId      String
  dayOfWeek           Int
  startMinutes        Int
  endMinutes          Int
  slotIntervalMinutes Int          @default(15)
  capacity            Int          @default(1)
  isActive            Boolean      @default(true)
  validFrom           DateTime?
  validUntil          DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  business            Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  professional        Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId, dayOfWeek, isActive])
  @@index([businessId, professionalId])
  @@index([createdAt])
}

model AvailabilityBlock {
  id             String        @id @default(cuid())
  businessId     String
  professionalId String?
  title          String?
  reason         String?
  allDay         Boolean       @default(false)
  startsAtUtc    DateTime
  endsAtUtc      DateTime
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  business       Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  professional   Professional? @relation(fields: [professionalId], references: [id], onDelete: SetNull)

  @@index([businessId, startsAtUtc])
  @@index([professionalId, startsAtUtc])
  @@index([createdAt])
}

model Customer {
  id                  String           @id @default(cuid())
  businessId          String
  fullName            String
  email               String?
  phone               String
  notes               String?          @db.Text
  privacyConsentAt    DateTime?
  marketingConsentAt  DateTime?
  timezone            String?
  lastBookedAt        DateTime?
  deletionRequestedAt DateTime?
  deletedAt           DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  business            Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointments        Appointment[]
  notifications       Notification[]
  reviews             Review[]
  privacyRequests     PrivacyRequest[]

  @@unique([businessId, phone])
  @@index([businessId, email])
  @@index([createdAt])
}

model Appointment {
  id                     String                     @id @default(cuid())
  businessId             String
  professionalId         String
  serviceId              String
  serviceVariantId       String?
  customerId             String
  locationId             String?
  status                 AppointmentStatus          @default(CONFIRMED)
  source                 AppointmentSource          @default(PUBLIC_PAGE)
  startsAtUtc            DateTime
  endsAtUtc              DateTime
  timezoneSnapshot       String
  customerTimezone       String?
  customerNameSnapshot   String
  customerEmailSnapshot  String?
  customerPhoneSnapshot  String
  serviceNameSnapshot    String
  serviceVariantSnapshot String?
  locationNameSnapshot   String?
  priceCents             Int
  prepaymentMode         ServicePrepaymentMode      @default(NONE)
  prepaymentAmountCents  Int?
  prepaymentCapturedAt   DateTime?
  cancellationReason     String?                    @db.Text
  internalNotes          String?                    @db.Text
  cancelledAt            DateTime?
  completedAt            DateTime?
  noShowMarkedAt         DateTime?
  googleCalendarEventId  String?
  version                Int                        @default(1)
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  business               Business                   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  professional           Professional               @relation(fields: [professionalId], references: [id], onDelete: Restrict)
  service                Service                    @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  serviceVariant         ServiceVariant?            @relation(fields: [serviceVariantId], references: [id], onDelete: SetNull)
  customer               Customer                   @relation(fields: [customerId], references: [id], onDelete: Restrict)
  location               BusinessLocation?          @relation(fields: [locationId], references: [id], onDelete: SetNull)
  notifications          Notification[]
  review                 Review?
  statusHistory          AppointmentStatusHistory[]
  accessTokens           AppointmentAccessToken[]

  @@unique([professionalId, startsAtUtc])
  @@index([professionalId, startsAtUtc])
  @@index([businessId, startsAtUtc])
  @@index([status])
  @@index([createdAt])
  @@index([customerId, createdAt])
}

model AppointmentStatusHistory {
  id              String             @id @default(cuid())
  appointmentId   String
  fromStatus      AppointmentStatus?
  toStatus        AppointmentStatus
  note            String?            @db.Text
  changedByUserId String?
  createdAt       DateTime           @default(now())
  appointment     Appointment        @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  changedByUser   User?              @relation(fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([appointmentId, createdAt])
  @@index([createdAt])
}

model AppointmentAccessToken {
  id            String             @id @default(cuid())
  businessId    String
  appointmentId String
  purpose       AccessTokenPurpose
  tokenHash     String             @unique
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime           @default(now())
  appointment   Appointment        @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  business      Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([appointmentId, purpose])
  @@index([createdAt])
}

model Plan {
  id                      String           @id @default(cuid())
  code                    PlanCode         @unique
  name                    String
  description             String?          @db.Text
  billingProvider         BillingProvider?
  trialDays               Int              @default(0)
  monthlyPriceCents       Int?
  yearlyPriceCents        Int?
  maxProfessionals        Int?
  maxServices             Int?
  maxMonthlyAppointments  Int?
  maxLocations            Int?
  customDomainEnabled     Boolean          @default(false)
  whatsappEnabled         Boolean          @default(false)
  remindersEnabled        Boolean          @default(true)
  scheduleBlocksEnabled   Boolean          @default(false)
  basicReportsEnabled     Boolean          @default(false)
  advancedReportsEnabled  Boolean          @default(false)
  googleCalendarEnabled   Boolean          @default(false)
  advancedBrandingEnabled Boolean          @default(false)
  prepaymentEnabled       Boolean          @default(false)
  publicApiEnabled        Boolean          @default(false)
  fullDataExportEnabled   Boolean          @default(false)
  prioritySupportEnabled  Boolean          @default(false)
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  subscriptions           Subscription[]

  @@index([createdAt])
}

model Subscription {
  id                     String             @id @default(cuid())
  businessId             String
  planId                 String
  provider               BillingProvider
  status                 SubscriptionStatus
  billingInterval        BillingInterval
  providerCustomerId     String?
  providerSubscriptionId String?            @unique
  providerPriceId        String?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  trialStart             DateTime?
  trialEnd               DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)
  canceledAt             DateTime?
  delinquentSince        DateTime?
  gracePeriodEndsAt      DateTime?
  newBookingsBlockedAt   DateTime?
  lastWebhookReceivedAt  DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  business               Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  plan                   Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([businessId, status])
  @@index([createdAt])
}

model BusinessUsageMonth {
  id                 String   @id @default(cuid())
  businessId         String
  periodKey          String
  appointmentsCount  Int      @default(0)
  professionalsCount Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  business           Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, periodKey])
  @@index([createdAt])
}

model NotificationTemplate {
  id            String              @id @default(cuid())
  businessId    String
  channel       NotificationChannel
  type          NotificationType
  subject       String?
  body          String              @db.Text
  isActive      Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  business      Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@unique([businessId, channel, type])
  @@index([createdAt])
}

model Notification {
  id              String                @id @default(cuid())
  businessId      String
  appointmentId   String?
  customerId      String?
  createdByUserId String?
  templateId      String?
  channel         NotificationChannel
  type            NotificationType
  status          NotificationStatus    @default(PENDING)
  recipientName   String?
  recipientEmail  String?
  recipientPhone  String?
  subject         String?
  body            String?               @db.Text
  payload         Json?
  scheduledFor    DateTime?
  sentAt          DateTime?
  failedAt        DateTime?
  errorMessage    String?               @db.Text
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  business        Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointment     Appointment?          @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  customer        Customer?             @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdByUser   User?                 @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  template        NotificationTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([businessId, status, scheduledFor])
  @@index([createdAt])
}

model Review {
  id                   String       @id @default(cuid())
  businessId           String
  professionalId       String
  appointmentId        String       @unique
  customerId           String?
  rating               Int
  title                String?
  body                 String?      @db.Text
  customerNameSnapshot String
  status               ReviewStatus @default(PENDING)
  isPublic             Boolean      @default(false)
  publishedAt          DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  business             Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  professional         Professional @relation(fields: [professionalId], references: [id], onDelete: Restrict)
  appointment          Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  customer             Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([businessId, isPublic, publishedAt])
  @@index([createdAt])
}

model PrivacyRequest {
  id             String               @id @default(cuid())
  businessId     String
  customerId     String?
  type           PrivacyRequestType
  status         PrivacyRequestStatus @default(OPEN)
  requesterName  String?
  requesterEmail String?
  requesterPhone String?
  note           String?              @db.Text
  resolvedAt     DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  business       Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer       Customer?            @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([businessId, status])
  @@index([createdAt])
}

model DataExport {
  id                String             @id @default(cuid())
  businessId        String
  requestedByUserId String
  format            DataExportFormat
  scope             DataExportScope
  status            NotificationStatus @default(PENDING)
  fileUrl           String?
  note              String?            @db.Text
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  completedAt       DateTime?
  business          Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  requestedByUser   User               @relation(fields: [requestedByUserId], references: [id], onDelete: Restrict)

  @@index([businessId, createdAt])
  @@index([createdAt])
}
